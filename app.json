{
  "expo": {
    "name": "egida",
    "slug": "egida",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "egida",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Égida necesita tu ubicación precisa para enviar alertas de seguridad y mostrarlas en el mapa.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Égida necesita acceso a tu ubicación para notificar alertas cercanas en tiempo real."
      },
      "config": {
        "googleMapsApiKey": "TU_API_KEY_DE_GOOGLE_MAPS_IOS"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#10172B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "TU_API_KEY_DE_GOOGLE_MAPS_ANDROID"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#10172B",
          "dark": {
            "backgroundColor": "#10172B"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Égida necesita tu ubicación para enviar y visualizar alertas de seguridad en el mapa."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}